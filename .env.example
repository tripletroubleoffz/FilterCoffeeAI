# -----------------------------------------------------------------------------
# Service Provider Abstractions Configuration
# -----------------------------------------------------------------------------
AUTH_PROVIDER="mock"      # Options: mock, clerk
PAYMENT_PROVIDER="mock"   # Options: mock, stripe
EMAIL_PROVIDER="mock"     # Options: mock, resend
AI_PROVIDER="mock"        # Options: mock, openai, anthropic, gemini
CACHE_PROVIDER="mock"     # Options: mock, redis
VECTOR_PROVIDER="mock"    # Options: mock, qdrant
STORAGE_PROVIDER="mock"   # Options: mock, s3

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@hostname:5432/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Clerk Authentication Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# -----------------------------------------------------------------------------
# Stripe Billing Configuration
# -----------------------------------------------------------------------------
STRIPE_API_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Resend Email Configuration
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."

# -----------------------------------------------------------------------------
# AI Model API Keys (Primary, Secondary, Fallback Routing)
# -----------------------------------------------------------------------------
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIzaSy..."

# -----------------------------------------------------------------------------
# Vector Database (Qdrant Cloud / Managed Cluster)
# -----------------------------------------------------------------------------
QDRANT_URL="https://xxx-xxxx.aws.qdrant.io:6333"
QDRANT_API_KEY="xxxx-xxxx-..."

# -----------------------------------------------------------------------------
# Background Queue Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_URL="rediss://default:password@redis-hostname:6379"

# -----------------------------------------------------------------------------
# Platform Metadata & Settings
# -----------------------------------------------------------------------------
NODE_ENV="production"
PORT=3000
NEXT_PUBLIC_APP_URL="https://filtercoffee.ai"

# -----------------------------------------------------------------------------
# NextAuth Configuration (Fallback compatibility)
# -----------------------------------------------------------------------------
NEXTAUTH_URL="https://filtercoffee.ai"
NEXTAUTH_SECRET="your-32-character-secret-key-placeholder"
