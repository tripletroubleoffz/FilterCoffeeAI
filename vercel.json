{
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/ingest?schedule=15min",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ingest?schedule=30min",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ingest?schedule=hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/ingest?schedule=daily",
      "schedule": "0 0 * * *"
    }
  ]
}