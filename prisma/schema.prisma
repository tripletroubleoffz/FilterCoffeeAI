generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  role            Role             @default(USER)
  status          UserStatus       @default(ACTIVE)
  authProvider    String           @default("SUPABASE")
  authId          String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  analytics       Analytics[]
  auditLogs       AuditLog[]
  bookmarks       Bookmark[]
  digests         Digest[]
  reports         Report[]
  subscription    Subscription?
  topics          Topic[]
  creditLedger    CreditLedger?
  aiGenerations   AiGeneration[]
  usageLogs       UsageLog[]
  feedbacks       Feedback[]
  contactMessages ContactMessage[]
  billingEvents   BillingEvent[]
  purchaseIntents PurchaseIntent[]

  @@index([email])
  @@index([authId])
  @@index([createdAt])
}

model Subscription {
  id                   String          @id @default(cuid())
  userId               String          @unique
  plan                 String          @default("FREE")
  billingCycle         String          @default("MONTHLY")
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique
  stripePriceId        String?
  status               String          @default("INACTIVE")
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodEnd     DateTime?
  renewalDate          DateTime?
  cancellationDate     DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?
  payments             Payment[]
  billingEvents        BillingEvent[]
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Int
  currency       String
  stripeChargeId String       @unique
  status         String
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

model CreditLedger {
  id               String              @id @default(cuid())
  userId           String              @unique
  currentBalance   Int                 @default(0)
  usedCredits      Int                 @default(0)
  purchasedCredits Int                 @default(0)
  bonusCredits     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     CreditTransaction[]

  @@index([userId])
}

model CreditTransaction {
  id            String       @id @default(cuid())
  ledgerId      String
  amount        Int
  balanceBefore Int          @default(0)
  balanceAfter  Int          @default(0)
  type          String       // GRANT, PURCHASE, RESERVE, DEDUCT, REFUND, SUBSCRIPTION, BONUS
  referenceId   String?
  description   String?
  createdAt     DateTime     @default(now())
  ledger        CreditLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([ledgerId])
  @@index([createdAt])
}

model AiGeneration {
  id               String    @id @default(cuid())
  userId           String
  prompt           String
  response         String
  modelUsed        String
  tokenCount       Int       @default(0)
  generationType   String    @default("TEXT")
  status           String    @default("SUCCESS")
  errorLogs        String?
  provider         String    @default("GEMINI")
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  providerCost     Float     @default(0.0)
  creditsConsumed  Int       @default(0)
  executionTime    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UsageLog {
  id            String    @id @default(cuid())
  userId        String
  action        String
  creditsUsed   Int       @default(0)
  tokensUsed    Int       @default(0)
  executionTime Int       @default(0)
  status        String
  resourceType  String?
  quantity      Int       @default(1)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Feedback {
  id        String    @id @default(cuid())
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BillingEvent {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String?
  eventType      String
  amount         Int?
  currency       String?
  stripeId       String?       @unique
  details        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([createdAt])
}

model Topic {
  id        String         @id @default(cuid())
  userId    String
  name      String
  frequency String         @default("DAILY")
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  digests   DigestTopic[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywords  TopicKeyword[]

  @@index([userId])
  @@index([isActive])
}

model TopicKeyword {
  id        String  @id @default(cuid())
  topicId   String
  keyword   String
  isExclude Boolean @default(false)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model Source {
  id              String    @id @default(cuid())
  name            String
  url             String    @unique
  type            String
  format          String    @default("RSS")
  category        String    @default("General")
  pollingInterval Int       @default(60)
  lastError       String?
  healthStatus    String    @default("HEALTHY")
  isActive        Boolean   @default(true)
  lastFetched     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  signals         Signal[]

  @@index([url])
  @@index([isActive])
}

model Signal {
  id          String         @id @default(cuid())
  sourceId    String?
  title       String
  content     String
  url         String?
  publishedAt DateTime
  category    String
  score       Float          @default(0.0)
  embeddingId String?
  createdAt   DateTime       @default(now())
  digests     DigestSignal[]
  source      Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([publishedAt])
  @@index([category])
}

model Digest {
  id        String         @id @default(cuid())
  userId    String
  title     String
  summary   String
  frequency String         @default("DAILY")
  createdAt DateTime       @default(now())
  sentAt    DateTime?
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  signals   DigestSignal[]
  topics    DigestTopic[]

  @@index([userId])
  @@index([createdAt])
}

model DigestTopic {
  digestId String
  topicId  String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([digestId, topicId])
}

model DigestSignal {
  digestId String
  signalId String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  signal   Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@id([digestId, signalId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  range     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CareerTrend {
  id        String   @id @default(cuid())
  type      String
  name      String
  value     String
  change    Float
  period    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model FinanceTrend {
  id        String   @id @default(cuid())
  ticker    String?
  name      String
  value     Float
  change    Float
  details   String?
  period    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AiTrend {
  id          String   @id @default(cuid())
  company     String
  type        String
  title       String
  description String
  importance  String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Analytics {
  id         String   @id @default(cuid())
  userId     String?
  event      String
  properties String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  details     String
  ipAddress   String?
  actor       String?
  entity      String?
  entityId    String?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model EmailLog {
  id        String   @id @default(cuid())
  email     String
  subject   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model ContactMessage {
  id        String    @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String?
  message   String
  status    String    @default("OPEN")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

enum PurchaseIntentStatus {
  PENDING
  REVIEWED
  CONTACTED
  APPROVED
  REJECTED
}

model PurchaseIntent {
  id               String               @id @default(cuid())
  userId           String?
  email            String
  currentPlan      String
  requestedPlan    String?
  requestedCredits Int?
  intentType       String
  billingFrequency String?
  sourcePage       String?
  userAgent        String?
  deviceType       String?
  country          String?
  referrer         String?
  status           PurchaseIntentStatus @default(PENDING)
  notes            String?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

// ==========================================
// PHASE 5: DYNAMIC INTELLIGENCE ENGINE
// ==========================================

model SourceProvider {
  id              String         @id @default(cuid())
  name            String
  url             String         @unique
  type            String         // RSS, API, SCRAPE
  format          String         @default("JSON")
  category        String         @default("AI")
  pollingInterval Int            @default(60) // in minutes
  lastError       String?
  healthStatus    String         @default("HEALTHY")
  isActive        Boolean        @default(true)
  lastFetched     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  contentItems    ContentItem[]

  @@index([url])
  @@index([isActive])
}

model ContentItem {
  id              String             @id @default(cuid())
  title           String
  summary         String?
  content         String
  source          String
  sourceType      String
  url             String             @unique
  author          String?
  publishedAt     DateTime
  imageUrl        String?
  language        String             @default("en")
  category        String
  industry        String?
  tags            String[]
  hash            String             @unique
  status          String             @default("PENDING") // PENDING, ENRICHED, CLUSTERED, PUBLISHED
  finalScore      Float              @default(0.0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  sourceProviderId String?
  provider         SourceProvider?   @relation(fields: [sourceProviderId], references: [id], onDelete: SetNull)
  
  enrichment      ContentEnrichment?
  
  clusterId       String?
  cluster         ContentCluster?    @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  @@index([sourceProviderId])
  @@index([publishedAt])
  @@index([category])
  @@index([status])
  @@index([hash])
}

model ContentEnrichment {
  id              String      @id @default(cuid())
  contentItemId   String      @unique
  aiSummary       String?
  keyTakeaways    String[]
  impactAnalysis  String?
  audiences       String[]
  importanceScore Float       @default(0.0)
  sentiment       String      @default("NEUTRAL") // POSITIVE, NEUTRAL, NEGATIVE
  trendDirection  String      @default("STABLE")  // RISING, STABLE, DECLINING
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  contentItem     ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@index([importanceScore])
  @@index([sentiment])
}

model ContentCluster {
  id               String        @id @default(cuid())
  theme            String
  summary          String?
  importance       Float         @default(0.0)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  items            ContentItem[]

  @@index([theme])
  @@index([importance])
}

model IngestionJob {
  id              String      @id @default(cuid())
  sourceName      String
  status          String      @default("RUNNING") // RUNNING, SUCCESS, FAILED
  itemsFetched    Int         @default(0)
  itemsAdded      Int         @default(0)
  duplicatesFound Int         @default(0)
  error           String?
  executionTimeMs Int         @default(0)
  createdAt       DateTime    @default(now())

  @@index([sourceName])
  @@index([status])
  @@index([createdAt])
}

model ContentAnalytics {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  articlesIngested Int      @default(0)
  duplicatesRemoved Int     @default(0)
  clustersCreated  Int      @default(0)
  topSources       Json?
  trendingTopics   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([date])
}

model DailyBrew {
  id                 String   @id @default(cuid())
  type               String   // MORNING, EVENING, WEEKLY, MONTHLY
  title              String
  headline           String
  sections           Json     // Organizes developments into Top Story, AI, Startups, Tech, Research, Business, and Trends
  whatChanged        String
  whyItMatters       String
  recommendedActions String[]
  priorityLevel      String   // CRITICAL, HIGH, MEDIUM, LOW
  createdAt          DateTime @default(now())
}

model AiRadarSignal {
  id                String   @id @default(cuid())
  category          String   // Product Launch, Startup Activity, Research, GitHub Intelligence
  title             String
  summary           String
  impact            String
  affectedUsers     String
  recommendedAction String
  impactScore       Int      @default(0)
  confidenceScore   Int      @default(0)
  relevanceScore    Int      @default(0)
  finalScore        Float    @default(0.0)
  sourceUrl         String?
  createdAt         DateTime @default(now())
}

model TrendTopic {
  id             String   @id @default(cuid())
  keyword        String   @unique
  countToday     Int      @default(0)
  countYesterday Int      @default(0)
  countPrevDay   Int      @default(0)
  velocity       Float    @default(0.0)
  growth         Float    @default(0.0)
  category       String   @default("General")
  updatedAt      DateTime @updatedAt
}

