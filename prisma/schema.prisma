datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  role          String         @default("USER") // "USER" or "ADMIN"
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clerkId       String         @unique
  
  subscription  Subscription?
  topics        Topic[]
  bookmarks     Bookmark[]
  digests       Digest[]
  reports       Report[]
  auditLogs     AuditLog[]
  analytics     Analytics[]
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId String             @unique
  stripePriceId    String?
  status           String             @default("INACTIVE") // INACTIVE, TRIALING, ACTIVE, PAST_DUE, CANCELED
  trialStart       DateTime?
  trialEnd         DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  payments         Payment[]
}

model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Int          // in cents
  currency       String
  stripeChargeId String       @unique
  status         String
  createdAt      DateTime     @default(now())
}

model Topic {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  keywords       TopicKeyword[]
  frequency      String         @default("DAILY") // DAILY, WEEKLY
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  digests        DigestTopic[]
}

model TopicKeyword {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  keyword   String
  isExclude Boolean  @default(false)
}

model Source {
  id          String   @id @default(cuid())
  name        String
  url         String   @unique
  type        String   // RSS, Github, HF, Job, Finance, NewsAPI
  isActive    Boolean  @default(true)
  lastFetched DateTime?
  createdAt   DateTime @default(now())
  signals     Signal[]
}

model Signal {
  id             String        @id @default(cuid())
  sourceId       String?
  source         Source?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title          String
  content        String
  url            String?
  publishedAt    DateTime
  category       String        // AI, Finance, Career, General
  score          Float         @default(0.0)
  embeddingId    String?       // Reference ID in Qdrant/Mock Vector DB
  createdAt      DateTime      @default(now())
  digests        DigestSignal[]
}

model Digest {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  summary     String         // AI-generated summary markdown
  frequency   String         @default("DAILY")
  createdAt   DateTime       @default(now())
  sentAt      DateTime?
  topics      DigestTopic[]
  signals     DigestSignal[]
}

model DigestTopic {
  digestId String
  topicId  String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  topic    Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@id([digestId, topicId])
}

model DigestSignal {
  digestId String
  signalId String
  digest   Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)
  signal   Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  @@id([digestId, signalId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  notes     String?
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   // Markdown content
  range     String   // WEEKLY, MONTHLY, YEARLY
  createdAt DateTime @default(now())
}

model CareerTrend {
  id        String   @id @default(cuid())
  type      String   // SKILL, ROLE, SALARY, HIRING, ADOPTION
  name      String
  value     String
  change    Float
  period    String   // WEEKLY, MONTHLY, YEARLY
  createdAt DateTime @default(now())
}

model FinanceTrend {
  id        String   @id @default(cuid())
  ticker    String?
  name      String
  value     Float
  change    Float
  details   String?
  period    String   // WEEKLY, MONTHLY, YEARLY
  createdAt DateTime @default(now())
}

model AiTrend {
  id          String   @id @default(cuid())
  company     String
  type        String
  title       String
  description String
  importance  String
  createdAt   DateTime @default(now())
}

model Analytics {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event     String
  properties String? // JSON serialized
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}

model EmailLog {
  id        String   @id @default(cuid())
  email     String
  subject   String
  status    String   // SENT, FAILED
  error     String?
  createdAt DateTime @default(now())
}
